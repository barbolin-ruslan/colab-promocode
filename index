      need:"Clicks by UTM + source (Instagram/email/partner banner)", status:"red" },
    { title:"LTV / retention 30/60/90 days", asker:"Ruslan", date:"hypothesis",
      why:"Excel 446 vs CSV 26 trips (HUBEES) gap = halo effect. Quantify it.",
      need:"Cohort of activated users, Cash GMV monthly for 90 days post-activation", status:"red" },
    { title:"CAC: promo vs. other channels", asker:"Ruslan", date:"hypothesis",
      why:"Without benchmarks we can't say if R$ 1.7/activation is cheap or expensive.",
      need:"CAC per channel (Meta, Google, ASO, referral) — blended 2026", status:"yellow" },
    { title:"Partner placement cost", asker:"Ruslan", date:"hypothesis",
      why:"Today we only track bonus. Blogger/partner fee is NOT included — real ROI may be lower.",
      need:"R$ paid to each partner per campaign (fee, % share, creative)", status:"yellow" },
    { title:"Geographic distribution", asker:"Ruslan", date:"hypothesis",
      why:"OndeIrBC should activate in SC; if it comes from SP there's a partner/region mismatch.",
      need:"Activations by city × promocode", status:"yellow" },
    { title:"W/W dynamics", asker:"Ilya", date:"2026-05-07",
      why:"«Weekly updates». Dynamics show if a campaign grows or dies.",
      need:"Automated weekly snapshot every Monday", status:"green" },
    { title:"UTM/source per activation", asker:"Ruslan", date:"hypothesis",
      why:"Without UTM we don't know which channel (Instagram, email, push, banner) works.",
      need:"utm_source column in activations report", status:"red" },
    { title:"Activation quality (anti-fraud)", asker:"Ruslan", date:"hypothesis",
      why:"ONDEIRBC1: 162 activations in 4 months via blogger with 300 codes. Check for farming.",
      need:"Fraud flags, device-id, suspicious patterns", status:"yellow" },
    { title:"Activation → 1st trip conversion (CR2)", asker:"Ruslan", date:"hypothesis",
      why:"CSV already has «first_trips» counts (8/27/105). Only cohort viz is missing.",
      need:"Days between activation and 1st trip + % activated who became riders", status:"yellow" },
  ],
};

const COLORS = ["#38BDF8","#F59E0B","#22C55E","#A78BFA","#EC4899","#14B8A6"];

// ============================================
// State
// ============================================
let lang = (navigator.language || "pt").slice(0,2);
if (!I18N[lang]) lang = "pt";
let activeFilter = "ALL";

function fmt(){ return new Intl.NumberFormat(I18N[lang].locale); }
function brl(){ return new Intl.NumberFormat(I18N[lang].locale, {style:"currency", currency:"BRL", maximumFractionDigits:0}); }
function pct(v){ return (v*100).toFixed(0) + "%"; }
function dateFmt(d){ return new Date(d).toLocaleDateString(I18N[lang].locale); }
const t = ()=> I18N[lang];

function setLang(l){ lang = l; document.documentElement.lang = I18N[l].locale; render(); }

// === Info modal helpers ===
function openInfo(key){
  const h = (HELP[lang] || HELP.pt)[key];
  if(!h) return;
  document.getElementById("infoTitle").textContent = h.title;
  document.getElementById("infoBody").innerHTML = h.body;
  document.getElementById("infoOk").textContent = (lang==="ru"?"Понятно":lang==="en"?"Got it":"Entendi");
  document.getElementById("infoOverlay").classList.add("open");
}
function closeInfo(){ document.getElementById("infoOverlay").classList.remove("open"); }
function infoBtn(key){ return `<button class="info-btn" data-help="${key}" aria-label="Info" title="?">i</button>`; }
// Delegated click handler for info buttons
document.addEventListener("click", e=>{
  const b = e.target.closest(".info-btn");
  if(b){ e.stopPropagation(); openInfo(b.dataset.help); return; }
  if(e.target.id === "infoClose" || e.target.id === "infoOk" || e.target.id === "infoOverlay") closeInfo();
});
document.addEventListener("keydown", e=>{ if(e.key === "Escape") closeInfo(); });

function renderHeader(){
  const T = t();
  document.getElementById("title").innerHTML = `${T.title_main} <span class="accent">${T.title_accent}</span>`;
  document.getElementById("subtitle").textContent = T.subtitle;
  document.getElementById("sources").innerHTML = T.sources;
  document.getElementById("assumptions").innerHTML = T.asm.map(a=>
    `<div class="assumption"><b>${a.b}</b>${a.s}</div>`
  ).join("");
  document.getElementById("footer").innerHTML = T.footer;
  document.getElementById("insightsTitle").innerHTML = T.insightsTitle;
  // chart titles
  document.getElementById("t_chGMV").textContent     = T.chart.gmv;
  document.getElementById("t_chGMVpill").textContent = T.chart.gmvPill;
  document.getElementById("t_chROI").textContent     = T.chart.roi;
  document.getElementById("t_chROIpill").textContent = T.chart.roiPill;
  document.getElementById("t_chAct").textContent     = T.chart.act;
  document.getElementById("t_chActpill").textContent = T.chart.actPill;
  document.getElementById("t_chMix").textContent     = T.chart.mix;
  document.getElementById("t_chMixpill").textContent = T.chart.mixPill;
  document.getElementById("t_tbl").textContent       = T.tbl.title;
  document.getElementById("t_tblpill").textContent   = T.tbl.pill;
  // active lang button
  document.querySelectorAll("#langSwitch button").forEach(b=>{
    b.classList.toggle("active", b.dataset.lang === lang);
  });
}

function renderFilters(){
  const T = t();
  const f = document.getElementById("filters");
  const opts = [{k:"ALL", l:T.all}, ...DATA.map(d=>({k:d.code, l:d.code}))];
  f.innerHTML = `<span class="label">${T.filter}</span>` +
    opts.map(o=>`<div class="chip ${activeFilter===o.k?'active':''}" data-k="${o.k}">${o.l}</div>`).join("");
  f.querySelectorAll(".chip").forEach(c=>c.addEventListener("click", ()=>{
    activeFilter = c.dataset.k; render();
  }));
}

function filtered(){ return activeFilter === "ALL" ? DATA : DATA.filter(d=>d.code===activeFilter); }

function renderKPIs(){
  const T = t();
  const d = filtered();
  const sum = (k)=> d.reduce((a,b)=>a+b[k], 0);
  const totalAct = sum("activations");
  const totalGMV = sum("gmv");
  const totalCash = sum("cash");
  const totalBonus = sum("bonus");
  const totalROI = totalBonus > 0 ? (totalCash - totalBonus)/totalBonus : 0;
  const F = fmt(); const B = brl();
  const items = [
    {lbl:T.kpi.codes,  val:F.format(d.length),                                                          help:"codes"},
    {lbl:T.kpi.act,    val:F.format(totalAct),                                                          help:"act"},
    {lbl:T.kpi.pctNew, val:(totalAct ? (sum("new_users")/totalAct*100).toFixed(1) : "0") + "%", cls:"green",  help:"pctNew"},
    {lbl:T.kpi.trips,  val:F.format(sum("trips")), cls:"orange",                                              help:"trips"},
    {lbl:T.kpi.gmv,    val:B.format(totalGMV), cls:"pink",                                                    help:"gmv"},
    {lbl:T.kpi.cash,   val:B.format(totalCash), cls:"green",                                                  help:"cash"},
    {lbl:T.kpi.bonus,  val:B.format(totalBonus), cls:"red",                                                   help:"bonus"},
    {lbl:T.kpi.roi,    val:pct(totalROI), cls: totalROI>=2?"green":(totalROI>=0?"orange":"red"),              help:"roi"},
  ];
  document.getElementById("kpis").innerHTML = items.map(i=>`
    <div class="kpi ${i.cls||''}">
      ${infoBtn(i.help)}
      <div class="lbl">${i.lbl}</div>
      <div class="val">${i.val}</div>
    </div>`).join("");
}

function renderInsights(){
  const T = t(); const B = brl(); const F = fmt();
  const sortedByROI = [...DATA].sort((a,b)=>b.roi - a.roi);
  const best  = sortedByROI[0];
  // "worst" = lowest budget utilization (least engaged audience)
  const sortedByUtil = [...DATA].sort((a,b)=>a.budgetUtil - b.budgetUtil);
  const worst = sortedByUtil[0];
  const totalCash = DATA.reduce((a,b)=>a+b.cash,0);
  const totalBonus = DATA.reduce((a,b)=>a+b.bonus,0);
  const totalROI = totalBonus ? (totalCash - totalBonus)/totalBonus : 0;
  const items = [
    `<span class="tag win">${T.tag.win}</span>${T.ins.win(best.code, pct(best.roi), F.format(best.trips), B.format(best.cash))}`,
    `<span class="tag warn">${T.tag.warn}</span>${T.ins.warn(worst.code, F.format(worst.trips), pct(worst.budgetUtil), F.format(worst.codes_issued))}`,
    `<span class="tag ok">${T.tag.ok}</span>${T.ins.ok(B.format(totalCash), B.format(totalBonus), pct(totalROI))}`,
    `<span class="tag info">${T.tag.next}</span>${T.ins.next}`,
  ];
  document.getElementById("insightsList").innerHTML = items.map(i=>`<li>${i}</li>`).join("");
}

function renderTable(){
  const T = t(); const F = fmt(); const B = brl();
  const head = document.getElementById("tblHead");
  head.innerHTML = T.tbl.head.map((h,i)=>`<th class="${i>=2?'num':''}">${h}</th>`).join("");

  const tbody = document.querySelector("#tbl tbody");
  const d = filtered();
  const maxAct = Math.max(...d.map(x=>x.activations), 1);
  const rowsHtml = d.map((r,i)=>{
    const w = (r.activations/maxAct)*100;
    const c = COLORS[i%COLORS.length];
    const profitCls = r.profit >= 0 ? "pos" : "neg";
    const roiCls    = r.roi    >= 0 ? "pos" : "neg";
    return `<tr>
      <td class="code">${r.code}</td>
      <td>${r.campaign}</td>
      <td class="num">${F.format(r.activations)}<div class="bar"><div style="width:${w}%; background:${c}"></div></div></td>
      <td class="num">${(r.pctNew*100).toFixed(1)}%</td>
      <td class="num">${F.format(r.trips)}</td>
      <td class="num">${B.format(r.gmv)}</td>
      <td class="num">${B.format(r.cash)}</td>
      <td class="num">${B.format(r.bonus)}</td>
      <td class="num ${profitCls}">${B.format(r.profit)}</td>
      <td class="num ${roiCls}">${pct(r.roi)}</td>
      <td class="num">${(r.budgetUtil*100).toFixed(2)}%</td>
    </tr>`;
  }).join("");

  const sum=(k)=>d.reduce((a,b)=>a+b[k],0);
  const tAct=sum("activations"), tGMV=sum("gmv"), tCash=sum("cash"), tBon=sum("bonus");
  const tProf = tCash - tBon;
  const tROI  = tBon ? tProf/tBon : 0;
  const tBudget = sum("budget_max");
  const tUtil = tBudget ? tBon/tBudget : 0;
  const totalRow = `<tr class="totals">
    <td>${T.tbl.total}</td><td></td>
    <td class="num">${F.format(tAct)}</td>
    <td class="num">${tAct? (sum("new_users")/tAct*100).toFixed(1) : 0}%</td>
    <td class="num">${F.format(sum("trips"))}</td>
    <td class="num">${B.format(tGMV)}</td>
    <td class="num">${B.format(tCash)}</td>
    <td class="num">${B.format(tBon)}</td>
    <td class="num ${tProf>=0?'pos':'neg'}">${B.format(tProf)}</td>
    <td class="num ${tROI>=0?'pos':'neg'}">${pct(tROI)}</td>
    <td class="num">${(tUtil*100).toFixed(2)}%</td>
  </tr>`;
  tbody.innerHTML = rowsHtml + totalRow;
}

let chartObjs={};
function destroy(n){ if(chartObjs[n]){ chartObjs[n].destroy(); delete chartObjs[n]; } }

function baseOpts(){
  return {
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{ labels:{ color:"#94A3B8", boxWidth:10 }}},
    scales:{
      x:{ ticks:{ color:"#94A3B8" }, grid:{ color:"#334155" }},
      y:{ ticks:{ color:"#94A3B8" }, grid:{ color:"#334155" }, beginAtZero:true }
    }
  };
}

function renderCharts(){
  const T = t(); const B = brl();
  const d = filtered();

  destroy("gmv");
  chartObjs.gmv = new Chart(document.getElementById("chGMV"), {
    type:"bar",
    data:{
      labels:d.map(x=>x.code),
      datasets:[
        {label:T.chartDS.cash,  data:d.map(x=>x.cash),  backgroundColor:"#22C55E"},
        {label:T.chartDS.bonus, data:d.map(x=>x.bonus), backgroundColor:"#EF4444"},
      ]
    },
    options:{...baseOpts(), plugins:{...baseOpts().plugins,
      tooltip:{ callbacks:{ label: ctx=>` ${ctx.dataset.label}: ${B.format(ctx.parsed.y)}` }}}}
  });

  destroy("roi");
  chartObjs.roi = new Chart(document.getElementById("chROI"), {
    type:"bar",
    data:{
      labels:d.map(x=>x.code),
      datasets:[{
        label:T.chartDS.roi,
        data:d.map(x=>x.roi*100),
        backgroundColor:d.map(x=>x.roi>=2?"#22C55E":(x.roi>=0?"#F59E0B":"#EF4444")),
      }]
    },
    options:{...baseOpts(), indexAxis:"y", plugins:{ legend:{display:false},
      tooltip:{ callbacks:{ label: ctx=>` ${T.chartDS.roi}: ${ctx.parsed.x.toFixed(0)}%` }}}}
  });

  destroy("act");
  chartObjs.act = new Chart(document.getElementById("chActivations"), {
    type:"bar",
    data:{
      labels:d.map(x=>x.code),
      datasets:[
        {label:T.chartDS.novos,  data:d.map(x=>x.new_users), backgroundColor:"#22C55E"},
        {label:T.chartDS.ativos, data:d.map(x=>Math.max(0, x.activations - x.new_users)), backgroundColor:"#38BDF8"},
      ]
    },
    options:{...baseOpts(), scales:{ x:{...baseOpts().scales.x, stacked:true}, y:{...baseOpts().scales.y, stacked:true}}}
  });

  destroy("mix");
  chartObjs.mix = new Chart(document.getElementById("chMix"), {
    type:"bar",
    data:{
      labels:d.map(x=>x.code),
      datasets:[{
        label:T.chartDS.util,
        data:d.map(x=>x.budgetUtil*100),
        backgroundColor:d.map(x=>x.budgetUtil>=0.05?"#22C55E":(x.budgetUtil>=0.01?"#F59E0B":"#EF4444")),
      }]
    },
    options:{...baseOpts(), plugins:{ legend:{display:false},
      tooltip:{ callbacks:{ label: ctx=>` ${T.chartDS.util}: ${ctx.parsed.y.toFixed(2)}% (bônus: ${B.format(d[ctx.dataIndex].bonus)} / máx: ${B.format(d[ctx.dataIndex].budget_max)})` }}}}
  });
}

function renderPending(){
  const T = t();
  document.getElementById("t_pendTitle").textContent = T.pending.title;
  document.getElementById("t_pendSub").textContent = T.pending.sub;
  const cards = PENDING_CARDS[lang] || PENDING_CARDS.pt;
  document.getElementById("pendingGrid").innerHTML = cards.map(c=>`
    <div class="pcard">
      <div class="status ${c.status}"></div>
      <div class="title">${c.title}</div>
      <div class="asker">${T.pending.askedBy}: <b>${c.asker}</b> · ${c.date}</div>
      <div class="why">${c.why}</div>
      <div class="need"><b>${T.pending.needLabel}:</b>${c.need}</div>
    </div>`).join("");
  document.getElementById("pendingLegend").innerHTML = T.pending.legend.map(i=>
    `<div class="item"><span class="dot" style="background:${i.c==='red'?'#EF4444':i.c==='yellow'?'#F59E0B':'#22C55E'}"></span>${i.l}</div>`
  ).join("");
}

function render(){ renderHeader(); renderFilters(); renderKPIs(); renderInsights(); renderTable(); renderCharts(); renderPending(); }

// Lang switch wiring
document.querySelectorAll("#langSwitch button").forEach(b=>{
  b.addEventListener("click", ()=> setLang(b.dataset.lang));
});

render();
</script>
