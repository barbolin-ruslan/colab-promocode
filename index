<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>JET Collaborations — Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root{
    --bg:#0F172A; --panel:#1E293B; --panel2:#334155; --line:#475569;
    --text:#E2E8F0; --muted:#94A3B8; --accent:#38BDF8; --green:#22C55E;
    --orange:#F59E0B; --red:#EF4444; --purple:#A78BFA; --pink:#EC4899;
  }
  *{box-sizing:border-box; font-family:-apple-system,"Segoe UI",Roboto,Arial,sans-serif;}
  body{margin:0; background:var(--bg); color:var(--text); padding:24px; min-height:100vh;}
  .header{display:flex; justify-content:space-between; align-items:flex-start; gap:24px; flex-wrap:wrap; margin-bottom:12px;}
  .header-left h1{margin:0 0 4px; font-size:24px; letter-spacing:-0.5px;}
  .header-left h1 .accent{color:var(--accent);}
  .sub{color:var(--muted); font-size:13px;}
  .lang-switch{display:flex; gap:4px; background:var(--panel); border:1px solid var(--line); border-radius:99px; padding:4px;}
  .lang-switch button{background:transparent; border:none; color:var(--muted); font-size:11px; font-weight:600; padding:6px 12px; border-radius:99px; cursor:pointer; letter-spacing:.5px; transition:all .15s;}
  .lang-switch button:hover{color:var(--text);}
  .lang-switch button.active{background:var(--accent); color:#0F172A;}
  .sources{color:var(--muted); font-size:11px; margin-bottom:24px;}
  .sources b{color:var(--text);}
  .row{display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:14px; margin-bottom:24px;}
  .kpi{background:var(--panel); border-radius:12px; padding:16px 18px; border:1px solid var(--line); position:relative; overflow:hidden;}
  .kpi:before{content:""; position:absolute; left:0; top:0; bottom:0; width:4px; background:var(--accent);}
  .kpi.green:before{background:var(--green);}
  .kpi.orange:before{background:var(--orange);}
  .kpi.purple:before{background:var(--purple);}
  .kpi.red:before{background:var(--red);}
  .kpi.pink:before{background:var(--pink);}
  .kpi .lbl{font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px;}
  .kpi .val{font-size:24px; font-weight:700; margin-top:6px;}
  .grid{display:grid; grid-template-columns:2fr 1fr; gap:20px; margin-bottom:24px;}
  @media (max-width:1000px){.grid{grid-template-columns:1fr;}}
  .panel{background:var(--panel); border-radius:12px; padding:18px 20px; border:1px solid var(--line);}
  .panel h3{margin:0 0 14px; font-size:14px; display:flex; justify-content:space-between; align-items:center; gap:10px;}
  .panel h3 .pill{font-size:10px; background:var(--panel2); padding:3px 8px; border-radius:99px; color:var(--muted); font-weight:500;}
  table{width:100%; border-collapse:collapse; font-size:13px;}
  th{text-align:left; padding:10px 8px; color:var(--muted); font-weight:500; border-bottom:1px solid var(--line); text-transform:uppercase; font-size:10px; letter-spacing:.5px;}
  th.num{text-align:right;}
  td{padding:11px 8px; border-bottom:1px solid #2A3A52; vertical-align:middle;}
  tr:last-child td{border-bottom:none;}
  tr.totals td{font-weight:700; color:var(--text); background:#13243C;}
  td.num{text-align:right; font-variant-numeric:tabular-nums;}
  td.code{font-weight:700; color:var(--accent);}
  td.pos{color:var(--green); font-weight:600;}
  td.neg{color:var(--red); font-weight:600;}
  .bar{height:6px; background:var(--panel2); border-radius:3px; overflow:hidden; margin-top:4px;}
  .bar > div{height:100%; border-radius:3px;}
  .filters{display:flex; gap:8px; margin-bottom:18px; flex-wrap:wrap; align-items:center;}
  .filters .label{font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-right:4px;}
  .chip{background:var(--panel); border:1px solid var(--line); padding:6px 14px; border-radius:99px; font-size:12px; cursor:pointer; transition:all .15s;}
  .chip:hover{border-color:var(--accent);}
  .chip.active{background:var(--accent); border-color:var(--accent); color:#0F172A; font-weight:600;}
  .chart-wrap{position:relative; height:280px;}
  .insights{background:linear-gradient(135deg, #1E293B 0%, #243447 100%); border-radius:12px; padding:18px 20px; border:1px solid var(--line); margin-bottom:24px;}
  .insights h3{margin:0 0 14px; font-size:14px;}
  .insights ul{margin:0; padding-left:20px; line-height:1.7; font-size:13px;}
  .insights li{margin-bottom:4px;}
  .insights .tag{display:inline-block; font-size:10px; padding:2px 7px; border-radius:99px; margin-right:6px; font-weight:600;}
  .insights .tag.win{background:#14532D; color:#86EFAC;}
  .insights .tag.warn{background:#7C2D12; color:#FED7AA;}
  .insights .tag.ok{background:#1E3A8A; color:#BFDBFE;}
  .insights .tag.info{background:#3F3F46; color:#D4D4D8;}
  .assumptions{display:flex; gap:14px; margin-bottom:14px; flex-wrap:wrap;}
  .assumption{background:var(--panel); border:1px dashed var(--line); padding:8px 14px; border-radius:8px; font-size:11px; color:var(--muted);}
  .assumption b{color:var(--text); font-size:14px; margin-right:6px;}
  .footer{color:var(--muted); font-size:11px; text-align:center; margin-top:20px; line-height:1.6;}
  .pending-section{margin-bottom:24px;}
  .pending-section .head{display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;}
  .pending-section h2{margin:0; font-size:16px; color:var(--text);}
  .pending-section h2 .muted{color:var(--muted); font-size:12px; font-weight:400; margin-left:8px;}
  .pending-grid{display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:12px;}
  .pcard{background:repeating-linear-gradient(45deg, #1E293B, #1E293B 8px, #243447 8px, #243447 16px); border:1px dashed var(--line); border-radius:10px; padding:14px 16px; position:relative; opacity:.88;}
  .pcard:hover{opacity:1; border-color:var(--accent);}
  .pcard .status{position:absolute; top:10px; right:10px; width:8px; height:8px; border-radius:50%;}
  .pcard .status.red{background:#EF4444; box-shadow:0 0 6px #EF4444;}
  .pcard .status.yellow{background:#F59E0B; box-shadow:0 0 6px #F59E0B;}
  .pcard .status.green{background:#22C55E; box-shadow:0 0 6px #22C55E;}
  .pcard .title{font-size:13px; font-weight:700; color:var(--text); margin-bottom:6px; padding-right:18px; line-height:1.3;}
  .pcard .asker{font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px;}
  .pcard .asker b{color:var(--accent); font-weight:600;}
  .pcard .why{font-size:12px; color:var(--text); line-height:1.5; margin-bottom:8px; opacity:.85;}
  .pcard .need{font-size:11px; color:var(--muted); line-height:1.4; padding-top:8px; border-top:1px dashed var(--panel2);}
  .pcard .need b{color:var(--text); display:block; margin-bottom:3px; font-size:10px; text-transform:uppercase; letter-spacing:.5px;}
  .pending-legend{display:flex; gap:14px; font-size:11px; color:var(--muted); margin-top:12px; align-items:center;}
  .pending-legend .item{display:flex; align-items:center; gap:5px;}
  .pending-legend .dot{width:8px; height:8px; border-radius:50%;}

  /* === Info button & modal === */
  .info-btn{
    display:inline-flex; align-items:center; justify-content:center;
    width:18px; height:18px; border-radius:50%;
    background:var(--panel2); color:var(--muted);
    border:1px solid var(--line); font-size:11px; font-weight:700; font-style:italic;
    font-family:"Georgia",serif;
    cursor:pointer; transition:all .15s; flex-shrink:0; user-select:none;
    padding:0; line-height:1;
  }
  .info-btn:hover{background:var(--accent); color:#0F172A; border-color:var(--accent); transform:scale(1.1);}
  .kpi .info-btn{position:absolute; top:10px; right:10px;}
  .panel h3 .info-btn{margin-left:auto;}
  .pcard .info-btn{position:absolute; top:10px; right:24px; width:16px; height:16px; font-size:10px;}
  .insights h3 .info-btn{margin-left:auto;}

  .info-overlay{
    display:none; position:fixed; inset:0; background:rgba(15,23,42,.85);
    z-index:1000; align-items:center; justify-content:center; padding:20px;
    backdrop-filter:blur(4px);
  }
  .info-overlay.open{display:flex;}
  .info-modal{
    background:var(--panel); border:1px solid var(--accent); border-radius:14px;
    padding:28px 30px 24px; max-width:520px; width:100%;
    box-shadow:0 20px 60px rgba(0,0,0,.5); position:relative;
    animation:slideUp .2s ease-out;
  }
  @keyframes slideUp{from{transform:translateY(10px); opacity:0;} to{transform:translateY(0); opacity:1;}}
  .info-modal h4{margin:0 0 14px; font-size:18px; color:var(--accent); display:flex; align-items:center; gap:10px;}
  .info-modal h4 .icon{
    display:inline-flex; align-items:center; justify-content:center;
    width:32px; height:32px; border-radius:50%; background:var(--accent); color:#0F172A;
    font-size:18px; font-weight:700; font-family:"Georgia",serif; font-style:italic;
  }
  .info-modal .body{font-size:14px; line-height:1.6; color:var(--text); margin-bottom:18px;}
  .info-modal .body p{margin:0 0 10px;}
  .info-modal .body p:last-child{margin-bottom:0;}
  .info-modal .body .example{background:#13243C; border-left:3px solid var(--accent); padding:10px 14px; border-radius:4px; margin-top:12px; font-size:13px; color:var(--muted);}
  .info-modal .body .example b{color:var(--text);}
  .info-modal .close{
    position:absolute; top:14px; right:14px; width:28px; height:28px;
    background:transparent; border:none; color:var(--muted); cursor:pointer;
    font-size:20px; border-radius:50%; display:flex; align-items:center; justify-content:center;
  }
  .info-modal .close:hover{background:var(--panel2); color:var(--text);}
  .info-modal .got-it{
    background:var(--accent); color:#0F172A; border:none; padding:8px 18px;
    border-radius:8px; font-weight:600; font-size:13px; cursor:pointer; transition:opacity .15s;
  }
  .info-modal .got-it:hover{opacity:.85;}
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <h1 id="title"></h1>
    <div class="sub" id="subtitle"></div>
  </div>
  <div class="lang-switch" id="langSwitch">
    <button data-lang="pt">PT</button>
    <button data-lang="ru">RU</button>
    <button data-lang="en">EN</button>
  </div>
</div>
<div class="sources" id="sources"></div>

<div class="assumptions" id="assumptions"></div>

<div class="filters" id="filters"></div>

<div class="row" id="kpis"></div>

<div class="insights">
  <h3><span id="insightsTitle"></span><button class="info-btn" data-help="insights" aria-label="Info">i</button></h3>
  <ul id="insightsList"></ul>
</div>

<div class="grid">
  <div class="panel">
    <h3><span id="t_chGMV"></span> <span class="pill" id="t_chGMVpill"></span><button class="info-btn" data-help="chartGMV" aria-label="Info">i</button></h3>
    <div class="chart-wrap"><canvas id="chGMV"></canvas></div>
  </div>
  <div class="panel">
    <h3><span id="t_chROI"></span> <span class="pill" id="t_chROIpill"></span><button class="info-btn" data-help="chartROI" aria-label="Info">i</button></h3>
    <div class="chart-wrap"><canvas id="chROI"></canvas></div>
  </div>
</div>

<div class="grid">
  <div class="panel">
    <h3><span id="t_chAct"></span> <span class="pill" id="t_chActpill"></span><button class="info-btn" data-help="chartAct" aria-label="Info">i</button></h3>
    <div class="chart-wrap"><canvas id="chActivations"></canvas></div>
  </div>
  <div class="panel">
    <h3><span id="t_chMix"></span> <span class="pill" id="t_chMixpill"></span><button class="info-btn" data-help="chartMix" aria-label="Info">i</button></h3>
    <div class="chart-wrap"><canvas id="chMix"></canvas></div>
  </div>
</div>

<div class="panel" style="margin-bottom:24px;">
  <h3><span id="t_tbl"></span> <span class="pill" id="t_tblpill"></span><button class="info-btn" data-help="table" aria-label="Info">i</button></h3>
  <table id="tbl"><thead><tr id="tblHead"></tr></thead><tbody></tbody></table>
</div>

<div class="pending-section">
  <div class="head">
    <h2><span id="t_pendTitle"></span> <span class="muted" id="t_pendSub"></span><button class="info-btn" data-help="pending" aria-label="Info" style="margin-left:10px; vertical-align:middle;">i</button></h2>
  </div>
  <div class="pending-grid" id="pendingGrid"></div>
  <div class="pending-legend" id="pendingLegend"></div>
</div>

<div class="footer" id="footer"></div>

<div class="info-overlay" id="infoOverlay">
  <div class="info-modal">
    <button class="close" id="infoClose" aria-label="Close">×</button>
    <h4><span class="icon">i</span><span id="infoTitle"></span></h4>
    <div class="body" id="infoBody"></div>
    <button class="got-it" id="infoOk"></button>
  </div>
</div>

